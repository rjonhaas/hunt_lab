# .env.example — copy to .env and fill in your values before running docker compose
#
# cp .env.example .env
# nano .env

# ── Required ──────────────────────────────────────────────────────────────────

# IP address of this Ubuntu host reachable by the Windows victim VM
# Used by Caldera so agents can beacon back, and by Fleet so remote agents
# know the Fleet Server address.
HOST_IP=192.168.1.100

# Elastic superuser password (set once; used by bootstrap and healthchecks)
ELASTIC_PASSWORD=HuntLab2026!

# Password set for the kibana_system internal account by bootstrap.sh
KIBANA_SYSTEM_PASSWORD=KibanaInternal2026!

# ── Set automatically by bootstrap.sh (do not edit manually) ─────────────────
# bootstrap.sh appends this line after creating the Fleet Server service token.
# If you need to re-run bootstrap, delete this line and re-run:
#   docker compose run --rm bootstrap
FLEET_SERVER_SERVICE_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────

# Elastic stack version — must be identical across elasticsearch, kibana,
# fleet-server, elastic-agent, and filebeat images
ELASTIC_VERSION=8.19.14

# LocalStack version
LOCALSTACK_VERSION=3.4

# Elasticsearch JVM heap size — halve your available RAM, max 31g
# E.g. on a 16 GB host: ES_HEAP=4g
ES_HEAP=4g

# LocalStack Pro token — if set, switches the localstack image to localstack-pro
# Leave empty to use Community mode (no EKS/ECS)
LOCALSTACK_AUTH_TOKEN=
